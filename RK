<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data Analyst — Interview Q&A</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0a0a0a;
  --paper: #f5f1e8;
  --cream: #ede8db;
  --red: #c8001a;
  --gold: #b89a4e;
  --muted: #7a7468;
  --border: rgba(13,13,13,0.14);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { background: var(--paper); color: var(--ink); font-family: 'Lora', serif; min-height: 100vh; }

/* Grain */
body::after {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 9999;
}

/* ══════════════════════════════
   LANDING PAGE
══════════════════════════════ */
#page-landing {
  position: fixed; inset: 0;
  background: var(--paper);
  display: flex; align-items: center; justify-content: center;
  z-index: 100;
  transition: opacity 0.6s ease, transform 0.6s ease;
}
#page-landing.exit {
  opacity: 0;
  transform: translateY(-40px);
  pointer-events: none;
}

/* Frame lines */
.rule-top, .rule-bottom { position: fixed; left:0; right:0; height:1px; background:var(--ink); opacity:0.18; z-index:101; }
.rule-top { top:48px; } .rule-bottom { bottom:48px; }
.rule-left, .rule-right { position:fixed; top:0; bottom:0; width:1px; background:var(--ink); opacity:0.18; z-index:101; }
.rule-left { left:48px; } .rule-right { right:48px; }
.corner { position:fixed; width:16px; height:16px; border-color:var(--ink); border-style:solid; opacity:0.3; z-index:101; }
.corner.tl { top:20px; left:20px; border-width:1px 0 0 1px; }
.corner.tr { top:20px; right:20px; border-width:1px 1px 0 0; }
.corner.bl { bottom:20px; left:20px; border-width:0 0 1px 1px; }
.corner.br { bottom:20px; right:20px; border-width:0 1px 1px 0; }

.issue-label {
  position:fixed; top:22px; left:50%; transform:translateX(-50%);
  font-family:'Bebas Neue',sans-serif; font-size:11px; letter-spacing:0.25em; color:var(--muted); z-index:102;
}
.bottom-label {
  position:fixed; bottom:22px; left:50%; transform:translateX(-50%);
  font-family:'Bebas Neue',sans-serif; font-size:10px; letter-spacing:0.3em; color:var(--muted); z-index:102;
}
.index-num {
  position:fixed; left:72px; bottom:72px;
  font-family:'Bebas Neue',sans-serif; font-size:120px; line-height:1;
  color:var(--ink); opacity:0.04; pointer-events:none; user-select:none; z-index:101;
}
.side-stats {
  position:fixed; right:72px; top:50%; transform:translateY(-50%);
  display:flex; flex-direction:column; gap:32px;
  opacity:0; animation:reveal 1s cubic-bezier(0.16,1,0.3,1) 1.1s forwards; z-index:101;
}
.stat { display:flex; flex-direction:column; align-items:flex-end; gap:4px; }
.stat-num { font-family:'Bebas Neue',sans-serif; font-size:32px; line-height:1; color:var(--ink); }
.stat-num .unit { font-size:16px; color:var(--gold); }
.stat-label { font-family:'Bebas Neue',sans-serif; font-size:9px; letter-spacing:0.2em; color:var(--muted); }
.stat-divider { width:1px; height:20px; background:var(--ink); opacity:0.15; align-self:flex-end; }

@keyframes reveal {
  from { opacity:0; transform:translateY(24px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes expand {
  from { opacity:0; transform:scaleX(0); }
  to   { opacity:1; transform:scaleX(1); }
}

.stage {
  display:flex; flex-direction:column; align-items:flex-start;
  opacity:0; animation:reveal 1.2s cubic-bezier(0.16,1,0.3,1) 0.2s forwards;
}
.eyebrow {
  font-family:'Bebas Neue',sans-serif; font-size:11px; letter-spacing:0.3em; color:var(--red);
  margin-bottom:10px; opacity:0; animation:reveal 1s cubic-bezier(0.16,1,0.3,1) 0.05s forwards;
}
.headline {
  font-family:'Bebas Neue',sans-serif; font-size:clamp(80px,14vw,160px);
  line-height:0.88; letter-spacing:-0.01em; color:var(--ink);
}
.word-create { display:block; opacity:0; animation:reveal 1s cubic-bezier(0.16,1,0.3,1) 0.15s forwards; }
.word-link {
  display:block; color:transparent; -webkit-text-stroke:2px var(--ink);
  opacity:0; animation:reveal 1s cubic-bezier(0.16,1,0.3,1) 0.28s forwards;
}
.accent-bar {
  width:60px; height:3px; background:var(--red); margin:28px 0 24px;
  opacity:0; animation:expand 1s cubic-bezier(0.16,1,0.3,1) 0.4s forwards; transform-origin:left;
}
.taglines { display:flex; flex-direction:column; gap:6px; }
.tagline {
  font-family:'DM Serif Display',serif; font-style:italic;
  font-size:clamp(18px,3vw,28px); color:var(--ink);
  opacity:0; animation:reveal 0.9s cubic-bezier(0.16,1,0.3,1) forwards;
}
.tagline:nth-child(1) { animation-delay:0.5s; }
.tagline:nth-child(2) { animation-delay:0.65s; }
.tagline:nth-child(3) {
  animation-delay:0.8s; color:var(--muted); font-style:normal;
  font-size:clamp(12px,1.5vw,15px); font-family:'Bebas Neue',sans-serif;
  letter-spacing:0.25em; margin-top:8px;
}
.cta-wrap { margin-top:44px; opacity:0; animation:reveal 0.9s cubic-bezier(0.16,1,0.3,1) 1s forwards; }
.cta {
  display:inline-flex; align-items:center; gap:14px;
  background:var(--ink); color:var(--paper);
  font-family:'Bebas Neue',sans-serif; font-size:14px; letter-spacing:0.25em;
  padding:18px 32px; text-decoration:none; border:none; cursor:pointer;
  position:relative; overflow:hidden; transition:all 0.3s ease;
}
.cta::before {
  content:''; position:absolute; inset:0; background:var(--red);
  transform:scaleX(0); transform-origin:left;
  transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
}
.cta:hover::before { transform:scaleX(1); }
.cta span, .cta .arrow { position:relative; z-index:1; }
.cta .arrow { display:inline-block; transition:transform 0.3s ease; }
.cta:hover .arrow { transform:translateX(6px); }

/* Cursor */
.cursor-dot {
  position:fixed; width:8px; height:8px; background:var(--red);
  border-radius:50%; pointer-events:none; z-index:9998;
  transform:translate(-50%,-50%); transition:width 0.3s, height 0.3s;
}
.cursor-ring {
  position:fixed; width:36px; height:36px; border:1px solid var(--ink);
  border-radius:50%; pointer-events:none; z-index:9997;
  transform:translate(-50%,-50%);
  transition:left 0.12s ease, top 0.12s ease, width 0.3s, height 0.3s, border-color 0.3s; opacity:0.4;
}
body.hovering .cursor-dot { width:12px; height:12px; }
body.hovering .cursor-ring { width:52px; height:52px; border-color:var(--red); opacity:0.6; }

/* ══════════════════════════════
   Q&A PAGE
══════════════════════════════ */
#page-qa {
  display: none;
  opacity: 0;
  transition: opacity 0.6s ease;
}
#page-qa.active {
  display: block;
  opacity: 1;
}

/* Header */
.qa-header {
  position:sticky; top:0;
  background:var(--ink); color:var(--paper);
  z-index:50; border-bottom:2px solid var(--red);
}
.header-inner {
  max-width:1200px; margin:0 auto; padding:0 40px;
  display:flex; align-items:center; justify-content:space-between; height:64px;
}
.header-logo { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:0.15em; color:var(--paper); }
.header-logo span { color:var(--red); }
.header-meta { font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.15em; color:rgba(245,241,232,0.45); text-align:right; }
.back-btn {
  font-family:'Bebas Neue',sans-serif; font-size:12px; letter-spacing:0.2em;
  color:var(--gold); background:none; border:none; cursor:pointer; padding:4px 0;
  transition:color 0.2s;
}
.back-btn:hover { color:var(--red); }

/* Hero */
.hero {
  background:var(--ink); color:var(--paper);
  padding:80px 40px 64px; position:relative; overflow:hidden;
}
.hero::before {
  content:'DA'; position:absolute; right:-20px; top:-40px;
  font-family:'Bebas Neue',sans-serif; font-size:320px; line-height:1;
  color:rgba(255,255,255,0.03); pointer-events:none; user-select:none;
}
.hero-inner {
  max-width:1200px; margin:0 auto;
  display:grid; grid-template-columns:1fr auto; gap:40px; align-items:end;
}
.hero-eyebrow { font-family:'Bebas Neue',sans-serif; font-size:11px; letter-spacing:0.35em; color:var(--red); margin-bottom:16px; }
.hero-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(52px,8vw,100px); line-height:0.9; }
.hero-title .outline { color:transparent; -webkit-text-stroke:1.5px var(--paper); }
.hero-desc { margin-top:24px; font-family:'Lora',serif; font-style:italic; font-size:17px; color:rgba(245,241,232,0.6); max-width:520px; line-height:1.7; }
.hero-stats { display:flex; flex-direction:column; gap:20px; text-align:right; border-left:1px solid rgba(245,241,232,0.12); padding-left:40px; }
.hero-stat-num { font-family:'Bebas Neue',sans-serif; font-size:40px; color:var(--gold); line-height:1; }
.hero-stat-label { font-family:'IBM Plex Mono',monospace; font-size:9px; letter-spacing:0.2em; color:rgba(245,241,232,0.4); margin-top:2px; }

/* Controls */
.controls { background:var(--cream); border-bottom:1px solid var(--border); position:sticky; top:64px; z-index:40; }
.controls-inner { max-width:1200px; margin:0 auto; padding:16px 40px; display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
.search-box { flex:1; min-width:200px; display:flex; align-items:center; gap:10px; background:var(--paper); border:1px solid var(--border); padding:10px 16px; }
.search-box input { border:none; background:transparent; font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--ink); outline:none; width:100%; }
.search-box input::placeholder { color:var(--muted); }
.search-icon { color:var(--muted); font-size:14px; flex-shrink:0; }
.filter-pills { display:flex; gap:8px; flex-wrap:wrap; }
.pill { font-family:'Bebas Neue',sans-serif; font-size:11px; letter-spacing:0.2em; padding:7px 16px; border:1px solid var(--border); background:transparent; color:var(--muted); cursor:pointer; transition:all 0.2s; }
.pill:hover { background:var(--ink); color:var(--paper); border-color:var(--ink); }
.pill.active { border-color:var(--red); background:var(--red); color:var(--paper); }
.count-badge { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--muted); margin-left:auto; white-space:nowrap; }

/* Content */
.qa-content { max-width:1200px; margin:0 auto; padding:48px 40px 80px; }
.category-section { margin-bottom:56px; }
.category-header { display:flex; align-items:baseline; gap:16px; margin-bottom:24px; padding-bottom:12px; border-bottom:2px solid var(--ink); }
.category-name { font-family:'Bebas Neue',sans-serif; font-size:28px; letter-spacing:0.05em; }
.category-num { font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--muted); letter-spacing:0.1em; }
.category-tag { margin-left:auto; font-family:'Bebas Neue',sans-serif; font-size:10px; letter-spacing:0.25em; padding:4px 10px; border:1px solid; }
.qa-grid { display:grid; gap:2px; }
.qa-card { background:var(--paper); border:1px solid var(--border); border-left:3px solid transparent; transition:border-left-color 0.2s, background 0.2s; cursor:pointer; }
.qa-card:hover { border-left-color:var(--red); background:#fff; }
.qa-card.open  { border-left-color:var(--red); background:#fff; }
.qa-question { padding:18px 24px; display:flex; align-items:flex-start; gap:16px; }
.q-num { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--muted); min-width:28px; padding-top:3px; letter-spacing:0.1em; }
.q-text { font-family:'Lora',serif; font-weight:600; font-size:15px; line-height:1.5; flex:1; color:var(--ink); }
.q-toggle { font-family:'IBM Plex Mono',monospace; font-size:18px; color:var(--muted); min-width:24px; text-align:center; transition:transform 0.3s, color 0.2s; line-height:1.5; }
.qa-card.open .q-toggle { transform:rotate(45deg); color:var(--red); }
.qa-answer { display:none; padding:16px 24px 20px 68px; font-family:'Lora',serif; font-size:14px; line-height:1.75; color:#3a3530; border-top:1px dashed var(--border); }
.qa-card.open .qa-answer { display:block; }
.qa-answer code { font-family:'IBM Plex Mono',monospace; font-size:12px; background:var(--cream); padding:2px 6px; border-radius:2px; color:var(--red); }
.qa-answer strong { color:var(--ink); font-weight:600; }

.back-top { position:fixed; bottom:32px; right:32px; background:var(--ink); color:var(--paper); font-family:'Bebas Neue',sans-serif; font-size:11px; letter-spacing:0.2em; padding:12px 16px; border:none; cursor:pointer; z-index:60; opacity:0; transition:opacity 0.3s; }
.back-top.visible { opacity:1; }
.back-top:hover { background:var(--red); }

.qa-footer { background:var(--ink); color:rgba(245,241,232,0.4); text-align:center; padding:28px 40px; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.2em; border-top:2px solid var(--red); }

.hidden { display:none !important; }

@media (max-width:768px) {
  .side-stats, .cursor-dot, .cursor-ring { display:none; }
  .index-num { font-size:80px; }
  .hero-inner { grid-template-columns:1fr; }
  .hero-stats { display:none; }
  .controls-inner { padding:12px 20px; }
  .qa-content { padding:32px 20px 60px; }
  .header-inner { padding:0 20px; }
  .hero { padding:48px 20px 40px; }
  .qa-answer { padding-left:24px; }
}
</style>
</head>
<body>

<!-- ═══ CURSOR ═══ -->
<div class="cursor-dot" id="dot"></div>
<div class="cursor-ring" id="ring"></div>

<!-- ═══════════════════════════════════════
     LANDING PAGE
═══════════════════════════════════════ -->
<div id="page-landing">
  <div class="rule-top"></div>
  <div class="rule-bottom"></div>
  <div class="rule-left"></div>
  <div class="rule-right"></div>
  <div class="corner tl"></div>
  <div class="corner tr"></div>
  <div class="corner bl"></div>
  <div class="corner br"></div>
  <div class="issue-label">CORPORATE EDITION &nbsp;·&nbsp; VOL. I</div>
  <div class="bottom-label">CONNECTIVITY &nbsp;·&nbsp; IMPACT &nbsp;·&nbsp; VISION</div>
  <div class="index-num">01</div>
  <div class="side-stats">
    <div class="stat"><div class="stat-num">1<span class="unit">×</span></div><div class="stat-label">Click</div></div>
    <div class="stat-divider"></div>
    <div class="stat"><div class="stat-num">∞</div><div class="stat-label">Reach</div></div>
    <div class="stat-divider"></div>
    <div class="stat"><div class="stat-num">∀</div><div class="stat-label">Dreams</div></div>
  </div>
  <main>
    <div class="stage">
      <div class="eyebrow">Data Analyst Interview Prep</div>
      <h1 class="headline">
        <span class="word-create">One</span>
        <span class="word-link">Click</span>
      </h1>
      <div class="accent-bar"></div>
      <div class="taglines">
        <div class="tagline">80+ Questions.</div>
        <div class="tagline">Many Answers.</div>
        <div class="tagline">Corporate Edition · 9 Categories</div>
      </div>
      <div class="cta-wrap">
        <button class="cta" id="ctaBtn">
          <span>Open Interview Guide</span>
          <span class="arrow">→</span>
        </button>
      </div>
    </div>
  </main>
</div>

<!-- ═══════════════════════════════════════
     Q&A PAGE
═══════════════════════════════════════ -->
<div id="page-qa">
  <header class="qa-header">
    <div class="header-inner">
      <div class="header-logo">Data<span>·</span>Analyst <span style="color:var(--gold);font-size:14px;margin-left:8px;">Q&A</span></div>
      <button class="back-btn" id="backToLanding">← Back</button>
      <div class="header-meta">INTERVIEW PREP GUIDE<br>CORPORATE EDITION</div>
    </div>
  </header>

  <div class="hero">
    <div class="hero-inner">
      <div>
        <div class="hero-eyebrow">Complete Interview Preparation</div>
        <h1 class="hero-title">Data Analyst<br><span class="outline">Questions</span></h1>
        <p class="hero-desc">Every essential question with concise, sharp answers — from SQL basics to business storytelling.</p>
      </div>
      <div class="hero-stats">
        <div><div class="hero-stat-num" id="totalCount">80+</div><div class="hero-stat-label">Questions</div></div>
        <div><div class="hero-stat-num">9</div><div class="hero-stat-label">Categories</div></div>
        <div><div class="hero-stat-num">100%</div><div class="hero-stat-label">Coverage</div></div>
      </div>
    </div>
  </div>

  <div class="controls">
    <div class="controls-inner">
      <div class="search-box">
        <span class="search-icon">⌕</span>
        <input type="text" id="searchInput" placeholder="Search questions…">
      </div>
      <div class="filter-pills" id="filterPills">
        <button class="pill active" data-cat="all">All</button>
        <button class="pill" data-cat="sql">SQL</button>
        <button class="pill" data-cat="stats">Statistics</button>
        <button class="pill" data-cat="excel">Excel</button>
        <button class="pill" data-cat="python">Python</button>
        <button class="pill" data-cat="viz">Visualization</button>
        <button class="pill" data-cat="business">Business</button>
        <button class="pill" data-cat="cleaning">Data Cleaning</button>
        <button class="pill" data-cat="behavioral">Behavioral</button>
        <button class="pill" data-cat="concepts">Concepts</button>
      </div>
      <div class="count-badge" id="countBadge">Showing 80 questions</div>
    </div>
  </div>

  <div class="qa-content" id="mainContent"></div>
  <button class="back-top" id="backTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑ TOP</button>
  <footer class="qa-footer">DATA ANALYST INTERVIEW GUIDE &nbsp;·&nbsp; ONE CLICK · MANY DREAMS · CORPORATE</footer>
</div>

<script>
// ─── DATA ───
const DATA = [
  { cat:"sql", label:"SQL & Databases", color:"#1a5276", questions:[
    {q:"What is SQL and why is it important for data analysts?",a:"SQL (Structured Query Language) is used to query, manipulate, and retrieve data from relational databases. It's essential because most business data lives in databases like MySQL, PostgreSQL, or SQL Server."},
    {q:"What is the difference between WHERE and HAVING?",a:"<strong>WHERE</strong> filters rows before aggregation. <strong>HAVING</strong> filters groups after a <code>GROUP BY</code>. Use HAVING only with aggregate functions like <code>COUNT</code>, <code>SUM</code>, etc."},
    {q:"Explain the types of JOINs in SQL.",a:"<strong>INNER JOIN</strong>: only matching rows from both tables. <strong>LEFT JOIN</strong>: all rows from the left + matches from right. <strong>RIGHT JOIN</strong>: opposite. <strong>FULL OUTER JOIN</strong>: all rows from both, with NULLs where no match."},
    {q:"What is a subquery?",a:"A query nested inside another query. It can appear in <code>SELECT</code>, <code>FROM</code>, or <code>WHERE</code> clauses. Example: <code>SELECT * FROM employees WHERE salary > (SELECT AVG(salary) FROM employees)</code>."},
    {q:"What are window functions?",a:"Functions that perform calculations across a set of rows related to the current row, without collapsing results like GROUP BY. Examples: <code>ROW_NUMBER()</code>, <code>RANK()</code>, <code>LAG()</code>, <code>LEAD()</code>, <code>SUM() OVER()</code>."},
    {q:"What is the difference between UNION and UNION ALL?",a:"<strong>UNION</strong> removes duplicate rows; <strong>UNION ALL</strong> keeps all rows including duplicates. UNION ALL is faster because it skips the deduplication step."},
    {q:"How do you find duplicate records in SQL?",a:"Use <code>GROUP BY</code> with <code>HAVING COUNT(*) > 1</code>. Example: <code>SELECT email, COUNT(*) FROM users GROUP BY email HAVING COUNT(*) > 1</code>."},
    {q:"What is the difference between DELETE, TRUNCATE, and DROP?",a:"<strong>DELETE</strong>: removes rows with a WHERE clause, logged. <strong>TRUNCATE</strong>: removes all rows fast, not logged per-row. <strong>DROP</strong>: removes the entire table and its structure."},
    {q:"What is indexing and why does it matter?",a:"An index is a data structure that speeds up row retrieval. It matters because without indexes, queries do full table scans — indexing columns used in WHERE, JOIN, or ORDER BY dramatically improves performance."},
    {q:"What is a CTE (Common Table Expression)?",a:"A temporary named result set defined with <code>WITH</code> that exists for the duration of one query. CTEs improve readability and allow recursive queries. Example: <code>WITH top_sales AS (SELECT ...)</code>."}
  ]},
  { cat:"stats", label:"Statistics & Analytics", color:"#1e8449", questions:[
    {q:"What is the difference between mean, median, and mode?",a:"<strong>Mean</strong>: arithmetic average. <strong>Median</strong>: middle value when sorted. <strong>Mode</strong>: most frequent value. Use median when data is skewed, as mean is sensitive to outliers."},
    {q:"What is standard deviation?",a:"A measure of how spread out values are around the mean. A low SD means data is clustered closely; a high SD means wide spread. Formula: square root of variance."},
    {q:"What is a p-value?",a:"The probability of observing results at least as extreme as the data, assuming the null hypothesis is true. A p-value < 0.05 typically means the result is statistically significant."},
    {q:"What is the Central Limit Theorem?",a:"As sample size increases, the distribution of the sample mean approaches a normal distribution, regardless of the original population's distribution. Foundation of many statistical tests."},
    {q:"Explain correlation vs. causation.",a:"Correlation means two variables move together. Causation means one variable directly causes change in another. Correlation does not imply causation — a third variable (confounder) may explain both."},
    {q:"What is A/B testing?",a:"A controlled experiment comparing two versions (A and B) to determine which performs better. Users are randomly split, and a statistical test determines if the difference is significant."},
    {q:"What is a confidence interval?",a:"A range of values that likely contains the true population parameter with a given confidence level (e.g., 95%). It reflects both the sample estimate and its uncertainty."},
    {q:"What is the difference between Type I and Type II errors?",a:"<strong>Type I</strong> (False Positive): rejecting a true null hypothesis. <strong>Type II</strong> (False Negative): failing to reject a false null hypothesis. The acceptable rates are α (alpha) and β (beta)."},
    {q:"What is variance?",a:"The average of squared differences from the mean. It measures data spread. High variance = data points far from mean. Variance is in squared units; standard deviation is the square root of variance."},
    {q:"What is skewness in data?",a:"<strong>Positive skew</strong>: tail on the right, mean > median (e.g., income). <strong>Negative skew</strong>: tail on the left, mean < median. Skewed data may require log transformation before analysis."}
  ]},
  { cat:"excel", label:"Excel & Spreadsheets", color:"#196f3d", questions:[
    {q:"What is a VLOOKUP and when would you use it?",a:"VLOOKUP looks up a value in the first column of a range and returns a value from a specified column. Use it to join tables. Syntax: <code>=VLOOKUP(key, range, col_index, FALSE)</code>. INDEX/MATCH is more flexible."},
    {q:"What is a Pivot Table?",a:"A tool to summarize, aggregate, and explore large datasets interactively. You drag fields to Rows, Columns, Values, and Filters to analyze data from different angles without writing formulas."},
    {q:"What is the difference between VLOOKUP and INDEX/MATCH?",a:"VLOOKUP only looks right and requires the key in the first column. INDEX/MATCH is more flexible — it can look in any direction and is faster on large datasets."},
    {q:"What are array formulas in Excel?",a:"Formulas that operate on multiple values simultaneously. In older Excel, entered with Ctrl+Shift+Enter. In Excel 365, dynamic arrays spill results automatically. Example: <code>=FILTER()</code>, <code>=UNIQUE()</code>."},
    {q:"How do you handle duplicates in Excel?",a:"Use <strong>Remove Duplicates</strong> under Data tab, or use formulas like <code>COUNTIF</code> to flag duplicates. In Excel 365, <code>=UNIQUE()</code> returns a deduplicated list."},
    {q:"What is conditional formatting?",a:"A feature that automatically applies formatting (colors, icons, bars) to cells based on rules or values. Useful for heatmaps, highlighting outliers, or traffic-light status indicators."},
    {q:"What is the SUMIFS function?",a:"<code>SUMIFS</code> sums values in a range based on multiple criteria. Syntax: <code>=SUMIFS(sum_range, criteria_range1, criteria1, ...)</code>. More powerful than SUMIF for multi-condition analysis."},
    {q:"What is Power Query?",a:"A data transformation tool in Excel (and Power BI) for importing, cleaning, and reshaping data without writing code. It records steps as a repeatable query for automation."}
  ]},
  { cat:"python", label:"Python for Data Analysis", color:"#7d6608", questions:[
    {q:"What Python libraries are most important for data analysis?",a:"<strong>Pandas</strong>: data manipulation. <strong>NumPy</strong>: numerical computing. <strong>Matplotlib/Seaborn</strong>: visualization. <strong>Scikit-learn</strong>: machine learning. <strong>SQLAlchemy</strong>: database connections."},
    {q:"What is a Pandas DataFrame?",a:"A 2D labeled data structure (like a spreadsheet/table) with rows and columns. It supports filtering, groupby, merge, reshape, and much more. Central to Python data analysis."},
    {q:"How do you handle missing values in Pandas?",a:"Use <code>df.isnull()</code> to find them. Options: <code>df.dropna()</code> to remove rows/columns, <code>df.fillna(value)</code> to fill with a constant, or interpolation methods for time-series data."},
    {q:"What is the difference between apply() and map() in Pandas?",a:"<strong>map()</strong>: element-wise on a Series. <strong>apply()</strong>: works on Series or DataFrame, can apply row/column-level functions. <strong>applymap()</strong>/<strong>map()</strong> (Pandas 2.1+): element-wise on DataFrames."},
    {q:"How do you merge DataFrames in Pandas?",a:"Use <code>pd.merge(df1, df2, on='key', how='left/right/inner/outer')</code> — similar to SQL JOINs. Or use <code>df.join()</code> for index-based merging."},
    {q:"What is a groupby operation?",a:"Groups rows sharing a value and applies an aggregation. Example: <code>df.groupby('region')['sales'].sum()</code>. Equivalent to SQL's <code>GROUP BY</code>. Supports sum, mean, count, min, max, and custom functions."},
    {q:"What is NumPy and how is it related to Pandas?",a:"NumPy provides fast n-dimensional array operations. Pandas is built on top of NumPy. Pandas DataFrames use NumPy arrays under the hood, so NumPy operations are fast and interoperable."},
    {q:"How do you read a CSV file in Python?",a:"Use <code>pd.read_csv('file.csv')</code>. You can specify encoding, delimiter, header row, date parsing, and dtype. For Excel: <code>pd.read_excel('file.xlsx')</code>."}
  ]},
  { cat:"viz", label:"Data Visualization", color:"#6e2f8a", questions:[
    {q:"What makes a good data visualization?",a:"Clarity, accuracy, and appropriate chart type for the data. Good viz eliminates chart junk, uses proper scales, labels axes clearly, and tells a story without distorting the data."},
    {q:"When should you use a bar chart vs. a line chart?",a:"<strong>Bar chart</strong>: comparing discrete categories. <strong>Line chart</strong>: showing trends over continuous time. Don't use lines for categorical data — it implies a false continuity."},
    {q:"What is a scatter plot used for?",a:"To show the relationship or correlation between two continuous variables. Points are plotted on x/y axes. You can add a trend line to visualize correlation direction and strength."},
    {q:"What is a box plot and what does it show?",a:"Shows distribution through 5 key stats: minimum, Q1 (25th percentile), median, Q3 (75th percentile), and maximum. The box spans the IQR; whiskers extend to 1.5×IQR; points beyond are outliers."},
    {q:"What is a heat map?",a:"A matrix visualization where cell color encodes a numerical value. Useful for showing correlations, website click patterns, or cross-tabulated data. Color gradient should be perceptually uniform."},
    {q:"What BI tools do data analysts commonly use?",a:"Tableau, Power BI, Looker, Metabase, and Redash are common. Power BI integrates with Microsoft stack. Tableau is strong for complex visualization. Looker (LookML) is popular in data-driven companies."},
    {q:"What is the difference between a histogram and a bar chart?",a:"A <strong>histogram</strong> shows the frequency distribution of a continuous variable — bars touch each other. A <strong>bar chart</strong> compares discrete categories with gaps between bars."},
    {q:"What is data storytelling?",a:"Communicating insights through a narrative structure using data and visuals. It involves a context, conflict (problem/opportunity), and resolution (insight/recommendation) — making data actionable for non-technical stakeholders."}
  ]},
  { cat:"business", label:"Business & Domain Knowledge", color:"#922b21", questions:[
    {q:"What are KPIs and how do you choose them?",a:"Key Performance Indicators are measurable metrics tied to business objectives. Choose KPIs that are SMART (Specific, Measurable, Achievable, Relevant, Time-bound) and directly linked to strategic goals."},
    {q:"What is cohort analysis?",a:"Groups users who share a characteristic (e.g., signup month) and tracks their behavior over time. Used to measure retention, LTV, or product engagement. Reveals how different cohorts perform relative to each other."},
    {q:"What is funnel analysis?",a:"Tracks user progression through sequential steps (e.g., visit → signup → purchase). Identifies where users drop off. Each stage's conversion rate reveals bottlenecks for optimization."},
    {q:"What is churn rate and how do you calculate it?",a:"Churn rate = (customers lost in period / customers at start of period) × 100. It measures customer attrition. High churn indicates retention problems; reducing churn is often more cost-effective than acquiring new customers."},
    {q:"What is Customer Lifetime Value (CLV)?",a:"The total revenue a business expects from a single customer over their entire relationship. CLV = Average Purchase Value × Purchase Frequency × Customer Lifespan. Helps justify acquisition costs."},
    {q:"What is the difference between metrics and dimensions?",a:"<strong>Metrics</strong> are quantitative measurements (revenue, sessions, conversions). <strong>Dimensions</strong> are qualitative attributes used to segment/filter metrics (region, device, product category)."},
    {q:"How would you measure the success of a new product feature?",a:"Define success metrics before launch (adoption rate, engagement, retention impact). Run an A/B test, measure against baseline, track qualitative feedback, and evaluate impact on core business KPIs."},
    {q:"What is DAU, MAU, and WAU?",a:"<strong>DAU</strong>: Daily Active Users. <strong>WAU</strong>: Weekly Active Users. <strong>MAU</strong>: Monthly Active Users. DAU/MAU ratio measures engagement stickiness — a ratio above 0.2 is considered strong."},
    {q:"What is MRR and ARR?",a:"<strong>MRR</strong> (Monthly Recurring Revenue): predictable revenue per month. <strong>ARR</strong> (Annual Recurring Revenue): MRR × 12. Core SaaS metrics for tracking growth, churn, and expansion revenue."}
  ]},
  { cat:"cleaning", label:"Data Cleaning & Quality", color:"#0e6655", questions:[
    {q:"What is data cleaning?",a:"The process of detecting and correcting (or removing) corrupt, inaccurate, incomplete, or duplicate records from a dataset. It's often 60–80% of a data analyst's work."},
    {q:"How do you handle missing data?",a:"Options: (1) Remove rows/columns with too many nulls. (2) Impute with mean/median/mode. (3) Use forward/backward fill for time series. (4) Flag nulls with an indicator variable. Choice depends on how data is missing."},
    {q:"What is an outlier and how do you handle it?",a:"A data point far from others. Identify using IQR method (±1.5×IQR) or z-score (|z|>3). Options: remove if it's an error, cap/floor it (winsorization), or use robust statistics that resist outlier influence."},
    {q:"What is data normalization vs. standardization?",a:"<strong>Normalization</strong>: scales values to [0,1] range. <strong>Standardization</strong> (Z-score): transforms to mean=0, SD=1. Use normalization for neural networks; standardization for algorithms assuming normal distribution."},
    {q:"What is data deduplication?",a:"The process of identifying and removing duplicate records. Can be exact (identical rows) or fuzzy (near-duplicates with slight variations). Tools include SQL <code>DISTINCT</code>, Pandas <code>drop_duplicates()</code>, or fuzzy matching libraries."},
    {q:"What is tidy data?",a:"A data structure principle by Hadley Wickham: (1) each variable is a column, (2) each observation is a row, (3) each type of observation is a separate table. Tidy data is easy to work with in analysis and visualization."},
    {q:"What is data validation?",a:"Checking that data meets defined rules: correct data types, value ranges, referential integrity, and format consistency. Done at ingestion to catch issues early before they propagate to reports."}
  ]},
  { cat:"behavioral", label:"Behavioral & Situational", color:"#4a235a", questions:[
    {q:"Tell me about a time you found a surprising insight in data.",a:"Use the STAR method: describe a Situation, the Task, your Action (how you dug into data), and the Result (what the insight was and what decision it informed). Emphasize curiosity and business impact."},
    {q:"How do you explain complex analysis to non-technical stakeholders?",a:"Avoid jargon. Lead with the business implication, not the methodology. Use visuals and analogies. Answer 'so what?' immediately. Always tie back to the decision or action the analysis supports."},
    {q:"How do you prioritize competing data requests?",a:"Assess urgency, business impact, and effort required. Communicate timelines transparently. Use a prioritization framework like ICE (Impact × Confidence ÷ Effort). Align with stakeholders on priorities proactively."},
    {q:"Describe a time your analysis was wrong. How did you handle it?",a:"Be honest and focus on learning. Describe what caused the error (data quality, assumption, methodology), how you caught it, how you corrected and communicated it, and what process you put in place to prevent recurrence."},
    {q:"How do you ensure your analysis is accurate?",a:"Validate inputs, cross-check results with multiple methods, sanity-check against known benchmarks, have someone else review, and document assumptions. Never skip QA even under time pressure."},
    {q:"How do you stay current with data tools and trends?",a:"Follow blogs (Towards Data Science, Mode Analytics), take courses (Coursera, DataCamp), participate in communities (dbt Slack, Kaggle), and apply new skills to personal projects or at work."}
  ]},
  { cat:"concepts", label:"Core Concepts & Theory", color:"#1a3a5c", questions:[
    {q:"What is the data analytics lifecycle?",a:"Define problem → Collect data → Clean & prepare → Explore (EDA) → Analyze & model → Visualize & communicate → Act on insights → Monitor outcomes. Each stage informs the next."},
    {q:"What is EDA (Exploratory Data Analysis)?",a:"The initial investigation of data using statistics and visualizations to summarize characteristics, find patterns, spot anomalies, and test assumptions before formal modeling or reporting."},
    {q:"What is the difference between structured and unstructured data?",a:"<strong>Structured</strong>: organized in rows/columns (databases, spreadsheets). <strong>Unstructured</strong>: no predefined schema (text, images, video, emails). Semi-structured (JSON, XML) sits in between."},
    {q:"What is OLTP vs OLAP?",a:"<strong>OLTP</strong> (Online Transaction Processing): optimized for fast read/write of individual transactions (order entry, banking). <strong>OLAP</strong> (Online Analytical Processing): optimized for complex queries over large historical data."},
    {q:"What is a data warehouse?",a:"A central repository of integrated data from multiple sources, optimized for analytical queries. Uses a star or snowflake schema. Examples: Snowflake, BigQuery, Redshift. Distinct from operational databases."},
    {q:"What is ETL?",a:"<strong>Extract</strong>: pull data from source systems. <strong>Transform</strong>: clean, reshape, enrich the data. <strong>Load</strong>: write to destination (warehouse, mart). ELT is the modern variant where transformation happens after loading."},
    {q:"What is the difference between a data lake and a data warehouse?",a:"A <strong>data lake</strong> stores raw, unstructured data at any scale cheaply (Parquet, JSON, CSV). A <strong>data warehouse</strong> stores structured, processed data optimized for queries. Modern lakehouses combine both."},
    {q:"What is a star schema?",a:"A dimensional modeling approach with one central fact table connected to multiple dimension tables. The fact table holds measurable events (sales, clicks); dimensions provide context (date, product, customer)."},
    {q:"What is the difference between batch and streaming data processing?",a:"<strong>Batch</strong>: processes large blocks of data at scheduled intervals (nightly ETL). <strong>Streaming</strong>: processes data continuously in real-time as it arrives (Kafka, Spark Streaming). Use case determines which fits."},
    {q:"What is data governance?",a:"The framework of policies, roles, and processes ensuring data is accurate, consistent, secure, and used appropriately. Covers data ownership, quality standards, privacy compliance (GDPR), and access control."}
  ]}
];

// ─── PAGE SWITCH ───
function showQA() {
  const landing = document.getElementById('page-landing');
  const qa = document.getElementById('page-qa');
  landing.classList.add('exit');
  setTimeout(() => {
    landing.style.display = 'none';
    qa.style.display = 'block';
    setTimeout(() => qa.classList.add('active'), 10);
    window.scrollTo(0,0);
    renderAll(DATA);
  }, 600);
}

function showLanding() {
  const landing = document.getElementById('page-landing');
  const qa = document.getElementById('page-qa');
  qa.classList.remove('active');
  setTimeout(() => {
    qa.style.display = 'none';
    landing.style.display = 'flex';
    landing.classList.remove('exit');
    window.scrollTo(0,0);
  }, 400);
}

document.getElementById('ctaBtn').addEventListener('click', showQA);
document.getElementById('backToLanding').addEventListener('click', showLanding);

// ─── RENDER Q&A ───
function renderAll(filteredData) {
  const content = document.getElementById('mainContent');
  content.innerHTML = '';
  let total = 0;
  filteredData.forEach((cat, ci) => {
    if (!cat.questions.length) return;
    total += cat.questions.length;
    const section = document.createElement('div');
    section.className = 'category-section';
    section.dataset.cat = cat.cat;
    section.innerHTML = `
      <div class="category-header">
        <span class="category-name">${cat.label}</span>
        <span class="category-num">${String(ci+1).padStart(2,'0')}</span>
        <span class="category-tag" style="color:${cat.color};border-color:${cat.color}">${cat.questions.length} Q</span>
      </div>
      <div class="qa-grid" id="grid-${cat.cat}"></div>
    `;
    content.appendChild(section);
    const grid = document.getElementById(`grid-${cat.cat}`);
    cat.questions.forEach((item, qi) => {
      const card = document.createElement('div');
      card.className = 'qa-card';
      card.innerHTML = `
        <div class="qa-question">
          <span class="q-num">Q${String(qi+1).padStart(2,'0')}</span>
          <span class="q-text">${item.q}</span>
          <span class="q-toggle">+</span>
        </div>
        <div class="qa-answer">${item.a}</div>
      `;
      card.querySelector('.qa-question').addEventListener('click', () => card.classList.toggle('open'));
      grid.appendChild(card);
    });
  });
  document.getElementById('countBadge').textContent = `Showing ${total} questions`;
  const allTotal = DATA.reduce((s,c) => s+c.questions.length, 0);
  const tc = document.getElementById('totalCount');
  if(tc) tc.textContent = allTotal + '+';
}

// ─── FILTER ───
document.getElementById('filterPills').addEventListener('click', e => {
  const pill = e.target.closest('.pill');
  if (!pill) return;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  pill.classList.add('active');
  const cat = pill.dataset.cat;
  renderAll(cat === 'all' ? DATA : DATA.filter(d => d.cat === cat));
  applySearch();
});

// ─── SEARCH ───
function applySearch() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  if (!q) { document.querySelectorAll('.qa-card').forEach(c => c.classList.remove('hidden')); updateCount(); return; }
  document.querySelectorAll('.qa-card').forEach(card => {
    const text = card.querySelector('.q-text').textContent.toLowerCase();
    const ans  = card.querySelector('.qa-answer').textContent.toLowerCase();
    const match = text.includes(q) || ans.includes(q);
    card.classList.toggle('hidden', !match);
    if (match) card.classList.add('open');
  });
  document.querySelectorAll('.category-section').forEach(sec => {
    sec.style.display = sec.querySelectorAll('.qa-card:not(.hidden)').length ? '' : 'none';
  });
  updateCount();
}
function updateCount() {
  const visible = document.querySelectorAll('.qa-card:not(.hidden)').length;
  document.getElementById('countBadge').textContent = `Showing ${visible} questions`;
}
document.getElementById('searchInput').addEventListener('input', applySearch);

// ─── BACK TO TOP ───
window.addEventListener('scroll', () => {
  document.getElementById('backTop').classList.toggle('visible', window.scrollY > 400);
});

// ─── CURSOR ───
const dot = document.getElementById('dot');
const ring = document.getElementById('ring');
document.addEventListener('mousemove', e => {
  dot.style.left = e.clientX+'px'; dot.style.top = e.clientY+'px';
  ring.style.left = e.clientX+'px'; ring.style.top = e.clientY+'px';
});
document.addEventListener('mouseover', e => {
  if (e.target.closest('a,button,.cta,.qa-card')) document.body.classList.add('hovering');
  else document.body.classList.remove('hovering');
});
</script>
